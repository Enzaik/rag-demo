{
  "name": "rag-showcase",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate --filter=@rag/db",
    "db:studio": "turbo run db:studio --filter=@rag/db",
    "shadcn:web": "pnpm --dir apps/web run shadcn",
    "seed": "pnpm --filter @rag/api run seed:products",
    "ingest": "turbo run ingest",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}