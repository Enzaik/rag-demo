# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Used by Drizzle (host/CLI) and the API at runtime.
DATABASE_URL=postgres://rag:rag@localhost:5432/rag

# ---------------------------------------------------------------------------
# OpenAI (embeddings + chat)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-replace-me

# ---------------------------------------------------------------------------
# Auth (better-auth on the API)
# ---------------------------------------------------------------------------
# Random 32+ char secret. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# API (Nest; also used by root docker-compose for the api service)
# ---------------------------------------------------------------------------
API_PORT=3001
# Browser origin for CORS (Next dev server by default).
WEB_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Service URLs
# ---------------------------------------------------------------------------
# Public URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:3001
# URL Next's server-side code uses to reach the API. On the host this is the
# same as NEXT_PUBLIC_API_URL; inside Docker it becomes http://api:3001.
API_INTERNAL_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Custom @rag component registry (your API — serves /r/*.json for shadcn CLI)
# ---------------------------------------------------------------------------
# Must NOT be named REGISTRY_URL: the shadcn CLI uses that env as the base for
# its own assets (e.g. /colors/neutral.json from the official registry).
RAG_COMPONENT_REGISTRY=http://localhost:3001
