{
  "name": "@rag/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "predev": "pnpm --filter @rag/db --filter @rag/shared run build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed:products": "tsx src/seed/products.seed.ts",
    "ingest:products": "tsx src/seed/ingest-products.ts",
    "ingest:markdown": "tsx src/seed/ingest-markdown.ts",
    "ingest": "pnpm ingest:products && pnpm ingest:markdown",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@rag/db": "workspace:*",
    "@rag/shared": "workspace:*",
    "better-auth": "^1.1.15",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "openai": "^4.76.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@rag/eslint-config": "workspace:*",
    "@rag/tsconfig": "workspace:*",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
